# ============================================
# Localisa Configuration
# ============================================

# --- LLM Backend ---
# Options: ollama | cloud | vllm | llamacpp | custom
LLM_BACKEND=ollama

# Ollama settings (when LLM_BACKEND=ollama)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b

# Cloud API settings (when LLM_BACKEND=cloud)
# Providers: deepseek | kimi | groq | claude | openai
LLM_CLOUD_PROVIDER=deepseek
LLM_CLOUD_API_KEY=
LLM_CLOUD_MODEL=deepseek-chat

# vLLM settings (when LLM_BACKEND=vllm)
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_MAX_MODEL_LEN=8192

# Custom URL (when LLM_BACKEND=custom)
LLM_CUSTOM_URL=http://localhost:8100/v1
LLM_CUSTOM_API_KEY=

# Fallback: use cloud API if local LLM fails
LLM_CLOUD_FALLBACK=false

# --- General ---
LOCALISA_LANG=es
WEB_PORT=8080
DATA_DIR=./data

# --- Embeddings ---
EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=cpu

# --- Voice (profile: voice) ---
WHISPER_MODEL=base
WHISPER_LANGUAGE=es
TTS_MODEL=es_MX-claude-high
TTS_SPEAKER=0

# --- Telegram (profile: telegram) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# --- Home Automation (profile: home) ---
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883

# --- Security ---
# Master password for encrypting vault (credentials, API keys)
LOCALISA_MASTER_PASSWORD=

# --- Plugins ---
# Comma-separated list of active plugins
PLUGINS=search,weather
